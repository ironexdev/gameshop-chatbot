        <mxCell id="z2IF-VTn-OaD9JBxBmtK-222" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=10;fontStyle=2;fontColor=#3F6B22;" value="Embeds widget.js" vertex="1">
          <mxGeometry height="20" width="160" x="1480" y="2740" as="geometry" />
        </mxCell>
        <mxCell id="z2IF-VTn-OaD9JBxBmtK-226" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" value="&lt;b style=&quot;font-size:13px;&quot;&gt;HTTP Backend process&lt;/b&gt; &lt;span style=&quot;color:#4F6E92;font-size:10px;&quot;&gt;(Node parent, client/src/index.ts)&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px;&quot;&gt;&amp;nbsp;•&amp;nbsp;&lt;b&gt;node:http&lt;/b&gt; server on PORT: routes, CORS, static serving of / and /widget.js&lt;br&gt;&amp;nbsp;•&amp;nbsp;&lt;b&gt;Chat orchestration loop&lt;/b&gt;: anthropic.messages.create tool-use loop, max 8 iterations/turn&lt;br&gt;&amp;nbsp;•&amp;nbsp;&lt;b&gt;MCP client&lt;/b&gt;: spawns and talks to the subprocess over stdio&lt;br&gt;&amp;nbsp;•&amp;nbsp;&lt;b&gt;Session store&lt;/b&gt;: in-memory Map&amp;lt;sessionId, Message[]&amp;gt;, cleared on restart&lt;/span&gt;" vertex="1">
          <mxGeometry height="120" width="480.05" x="1239.95" y="3000" as="geometry" />
        </mxCell>
        <mxCell id="z2IF-VTn-OaD9JBxBmtK-227" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" value="&lt;b style=&quot;font-size:13px;&quot;&gt;MCP Server subprocess&lt;/b&gt; &lt;span style=&quot;color:#4F6E92;font-size:10px;&quot;&gt;(Node child of the backend, server/src/index.ts, @modelcontextprotocol/sdk)&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px;&quot;&gt;&amp;nbsp;•&amp;nbsp;Exposes tools: &lt;b&gt;search_games&lt;/b&gt;, &lt;b&gt;get_game&lt;/b&gt;, &lt;b&gt;get_order&lt;/b&gt; (requires order_id + email)&lt;br&gt;&amp;nbsp;•&amp;nbsp;Order-lookup gate is enforced in &lt;b&gt;tool code&lt;/b&gt;, not in the prompt, so the LLM cannot bypass it&lt;br&gt;&amp;nbsp;•&amp;nbsp;&lt;b&gt;Data&lt;/b&gt;: games[] and orders[] arrays, loaded once from games.json / orders.json via readFileSync at startup&lt;/span&gt;" vertex="1">
          <mxGeometry height="159.81" width="480.05" x="1239.95" y="3200" as="geometry" />
        </mxCell>

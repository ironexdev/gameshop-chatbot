        <mxCell id="z2IF-VTn-OaD9JBxBmtK-238" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=light-dark(#808080, #d7817e);dashed=1;dashPattern=8 8;verticalAlign=top;fontSize=10;fontStyle=2;fontColor=#808080;align=left;spacingLeft=8;spacingTop=4;" value="" vertex="1">

        <mxCell id="z2IF-VTn-OaD9JBxBmtK-239" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;dashed=1;align=left;verticalAlign=top;fontSize=10;spacingLeft=8;spacingTop=8;fontFamily=Helvetica;fontColor=default;" value="&lt;b&gt;System prompt + tool-use loop&lt;/b&gt;&lt;br&gt;- Czech-only persona (&quot;GameShop&quot;)&lt;br&gt;- Max 8 iterations of tool-use per turn&lt;br&gt;- Full message history sent each turn" vertex="1">
          <mxGeometry height="120" width="260" x="1239.9536810980903" y="3559.995139973958" as="geometry" />
        </mxCell>
        <mxCell id="z2IF-VTn-OaD9JBxBmtK-240" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;dashed=1;align=left;verticalAlign=top;fontSize=10;spacingLeft=8;spacingTop=8;fontFamily=Helvetica;fontColor=default;" value="&lt;b&gt;Session + history handling&lt;/b&gt;&lt;br&gt;- sessionId from widget (localStorage UUID)&lt;br&gt;- History kept server-side in the Map&lt;br&gt;- Widget also mirrors messages in localStorage (UX only, not auth)" vertex="1">
          <mxGeometry height="120" width="260" x="1519.9536810980903" y="3559.995139973958" as="geometry" />
        </mxCell>
        <mxCell id="z2IF-VTn-OaD9JBxBmtK-241" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;dashed=1;align=left;verticalAlign=top;fontSize=10;spacingLeft=8;spacingTop=8;" value="&lt;b&gt;Order-lookup guardrail&lt;/b&gt;&lt;br&gt;get_order needs BOTH:&lt;br&gt;- order_id&lt;br&gt;- email&lt;br&gt;Enforced in &lt;b&gt;tool code&lt;/b&gt; inside the MCP subprocess, not in the prompt." vertex="1">
          <mxGeometry height="120" width="260" x="1799.9536810980903" y="3559.995139973958" as="geometry" />
        </mxCell>
        <mxCell id="z2IF-VTn-OaD9JBxBmtK-242" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;dashed=1;align=left;verticalAlign=top;fontSize=10;spacingLeft=8;spacingTop=8;" value="&lt;b&gt;Ambiguous error on mismatch&lt;/b&gt;&lt;br&gt;On a bad order_id + email pair the tool returns &quot;not_found_or_unauthorized&quot;. The assistant is instructed NOT to reveal which field was wrong." vertex="1">

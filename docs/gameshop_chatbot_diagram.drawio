        <mxCell id="z2IF-VTn-OaD9JBxBmtK-235" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;fontStyle=2;fontColor=#7D6608;" value="&lt;div&gt;Every tool-use iteration = one&lt;/div&gt;&lt;div&gt;messages.create({system, tools, messages}).&lt;/div&gt;&lt;div&gt;The &lt;b&gt;tools&lt;/b&gt; field is filled once at startup&lt;/div&gt;&lt;div&gt;from the MCP subprocess and resent every call.&lt;/div&gt;" vertex="1">
